{
	"name": "sandhost",
	"version": "0.0.1",
	"description": "distributed sandbox hosting using microsandboxes",
	"author": "wtrn.dev",
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"dev:api": "turbo dev --filter=@wtrn/api",
		"dev:web": "turbo dev --filter=@wtrn/web",
		"dev:runner": "turbo dev --filter=@wtrn/runner",
		"check": "oxlint --fix && oxfmt",
		"db:generate": "pnpm --filter @wtrn/db db:generate",
		"db:migrate": "pnpm --filter @wtrn/db db:migrate",
		"db:studio": "pnpm --filter @wtrn/db db:studio",
		"postgres:up": "docker compose up -d postgres",
		"postgres:down": "docker compose down"
	},
	"devDependencies": {
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
		"turbo": "catalog:"
	},
	"packageManager": "pnpm@10.32.1"
}
